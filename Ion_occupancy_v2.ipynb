{
 "cells": [
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [],
   "source": [
    "import MDAnalysis as mda\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from MDAnalysis.analysis import contacts"
    "from MDAnalysis.analysis import distances"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 62,
   "metadata": {},
   "outputs": [],
   "source": [
    "topology = \"../pendrin_md_0ns.pdb\"  # or .psf, .tpr, etc.\n",
    "trajectory = \"../pendrin_md_1us.dcd\" # or .dcd, .xtc, etc.\n",
    "\n",
    "ion_sel = \"resname O31\"  # adjust to your ions\n",
    "#protein_sel = \"segid A and (resid 105 or resid 141 or resid 408)\"  #Cytosolic side binding site\n",
    "protein_sel = \"segid A and (resid 230 or resid 237)\" #Extracellular side binding site\n",
    "cutoff = 3.5  # Å distance cutoff for contact"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 63,
   "metadata": {},
   "outputs": [],
   "source": [
    "u = mda.Universe(topology, trajectory)\n",
    "ions = u.select_atoms(ion_sel)\n",
    "protein = u.select_atoms(protein_sel)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 64,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ion residue IDs for grouping atoms to ions\n",
    "ion_resids = [atom.resid for atom in ions]\n",
    "unique_ion_resids = sorted(set(ion_resids))\n",
    "n_ions = len(unique_ion_resids)\n",
    "\n",
    "frame_with_any_bound = 0\n",
    "sum_fraction_bound = 0.0\n",
    "n_frames = len(u.trajectory)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 65,
   "metadata": {},
   "outputs": [],
   "source": [
    "for ts in u.trajectory:\n",
    "    ion_positions = ions.positions\n",
    "    prot_positions = protein.positions\n",
    "\n",
    "    # distance array (ions → protein)\n",
    "    dists = distances.distance_array(ion_positions, prot_positions)\n",
    "\n",
    "    # count how many ions are bound to the binding site for each frame\n",
    "    bound_ions_in_frame = 0\n",
    "    for resid in unique_ion_resids:\n",
    "        atom_indices = [i for i, r in enumerate(ion_resids) if r == resid]\n",
    "        # check if any atom of this ion is within cutoff\n",
    "        if (dists[atom_indices] < cutoff).any():\n",
    "            bound_ions_in_frame += 1\n",
    "\n",
    "    if bound_ions_in_frame > 0:\n",
    "        frame_with_any_bound += 1\n",
    "\n",
    "    sum_fraction_bound += (bound_ions_in_frame / n_ions)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 66,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total frames: 5000\n",
      "Ion occupancy (definition A): 0.0380\n"
     ]
    }
   ],
   "source": [
    "# Compute occupancies\n",
    "occupancy_A = frame_with_any_bound / n_frames\n",
    "\n",
    "# Print results\n",
    "print(f\"Ion occupancy (definition A): {occupancy_A:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": []
  }
